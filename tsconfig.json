{
  "compilerOptions": {
    "rootDir": "./scripts/src",
    "outDir": "./scripts/dist",

    "module": "esnext",
    "target": "esnext",
    "types": [],
    "lib": ["ESNext", "DOM"],

    "sourceMap": false,
    "declaration": true,
    "declarationMap": false,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },
  "exclude": [
    "./dist"
  ]
}
